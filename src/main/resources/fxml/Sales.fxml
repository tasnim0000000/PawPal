<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
fx:controller="com.example.pawpal.controller.SalesController" prefWidth="950" prefHeight="650">
<top><HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color:#355E3B;-fx-padding:15;"><children>
<Label text="💰 Sales" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
<Pane HBox.hgrow="ALWAYS"/>
<Button text="Back" onAction="#goBack"/>
</children></HBox></top>
<center><VBox spacing="15" style="-fx-padding:20;"><children>
<HBox spacing="30"><children>
<VBox alignment="CENTER" prefWidth="180" style="-fx-background-color:white;-fx-padding:15;"><children><Label text="Completed Sales"/><Label fx:id="lblTotalSales" style="-fx-font-size:22;-fx-font-weight:bold;"/></children></VBox>
<VBox alignment="CENTER" prefWidth="220" style="-fx-background-color:white;-fx-padding:15;"><children><Label text="Total Revenue"/><Label fx:id="lblTotalRevenue" style="-fx-font-size:22;-fx-font-weight:bold;"/></children></VBox>
</children></HBox>
<TableView fx:id="tableSales" prefHeight="450">
<columns>
<TableColumn fx:id="colOrderId" text="Order ID" prefWidth="80"/>
<TableColumn fx:id="colPet" text="Pet" prefWidth="150"/>
<TableColumn fx:id="colBuyer" text="Buyer" prefWidth="150"/>
<TableColumn fx:id="colPrice" text="Price (BDT)" prefWidth="120"/>
<TableColumn fx:id="colCompletedAt" text="Completed On" prefWidth="130"/>
</columns>
</TableView>
</children></VBox></center>
</BorderPane>
