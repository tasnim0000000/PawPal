<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
fx:controller="com.example.pawpal.controller.MyOrdersController" prefWidth="1050" prefHeight="700">
<top><HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color:#355E3B;-fx-padding:15;"><children>
<Label text="📦 My Orders" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
<Pane HBox.hgrow="ALWAYS"/>
<Button text="Refresh" onAction="#loadOrders"/>
<Button text="Back" onAction="#goBack"/>
</children></HBox></top>
<center><VBox spacing="15" style="-fx-padding:20;"><children>
<TableView fx:id="tableOrders" prefHeight="550">
<columns>
<TableColumn fx:id="colOrderId" text="Order ID" prefWidth="70"/>
<TableColumn fx:id="colPet" text="Pet" prefWidth="150"/>
<TableColumn fx:id="colStore" text="Store" prefWidth="160"/>
<TableColumn fx:id="colPrice" text="Price (BDT)" prefWidth="100"/>
<TableColumn fx:id="colPayment" text="Payment" prefWidth="130"/>
<TableColumn fx:id="colStatus" text="Status" prefWidth="180"/>
<TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
</columns>
</TableView>
<HBox spacing="15"><children>
<Button text="Confirm Receipt" onAction="#confirmReceipt"/>
<Button text="Cancel Order" onAction="#cancelOrder"/>
</children></HBox>
</children></VBox></center>
</BorderPane>
