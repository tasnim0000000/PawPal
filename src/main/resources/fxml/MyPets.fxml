<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
fx:controller="com.example.pawpal.controller.MyPetsController" prefWidth="1000" prefHeight="700">
<top><HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color:#355E3B;-fx-padding:15;"><children>
<Label text="🐾 My Pets" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
<Pane HBox.hgrow="ALWAYS"/><Button text="Refresh" onAction="#loadPets"/>
</children></HBox></top>
<center><VBox spacing="15" style="-fx-padding:20;"><children>
<TableView fx:id="tablePets" prefHeight="550">
<columns>
<TableColumn fx:id="colId" text="ID" prefWidth="60"/>
<TableColumn fx:id="colName" text="Pet Name" prefWidth="170"/>
<TableColumn fx:id="colSpecies" text="Species" prefWidth="120"/>
<TableColumn fx:id="colBreed" text="Breed" prefWidth="140"/>
<TableColumn fx:id="colPrice" text="Price (BDT)" prefWidth="120"/>
<TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
</columns>
</TableView>
<HBox spacing="15"><children>
<Button text="Edit Selected" onAction="#editPet"/>
<Button text="Delete Selected" onAction="#deletePet"/>
<Button text="Back" onAction="#goBack"/>
</children></HBox>
</children></VBox></center>
</BorderPane>
