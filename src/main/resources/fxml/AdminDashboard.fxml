<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pawpal.controller.AdminDashboardController"
            prefWidth="1200" prefHeight="750">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color:#355E3B;-fx-padding:15;">
            <children>
                <Label text="🐾 PawPal Admin"
                       style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblAdmin" text="Administrator"
                       style="-fx-text-fill:white;-fx-font-size:18;"/>
                <Button text="Logout" onAction="#logout"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="230"
              style="-fx-background-color:#4F6D4A;-fx-padding:20;">
            <children>
                <Button text="🏠 Dashboard" maxWidth="Infinity" onAction="#openDashboard"/>
                <Button text="🏪 Approve Stores" maxWidth="Infinity" onAction="#openStores"/>
                <Button text="🐶 Manage Pets" maxWidth="Infinity" onAction="#openPets"/>
                <Button text="⚠ Reports" maxWidth="Infinity" onAction="#openReports"/>
                <Button text="👥 Manage Users" maxWidth="Infinity" onAction="#openUsers"/>
                <Button text="📊 Statistics" maxWidth="Infinity" onAction="#openStatistics"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-background-color:#F7EAD9;-fx-padding:20;">
            <children>
                <Label text="Administrator Dashboard"
                       style="-fx-font-size:28;-fx-font-weight:bold;"/>

                <HBox spacing="20">
                    <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color:white;-fx-padding:15;">
                        <children><Label text="Pending Stores"/><Label fx:id="lblPendingStores" text="0"/></children>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color:white;-fx-padding:15;">
                        <children><Label text="Reported Pets"/><Label fx:id="lblReports" text="0"/></children>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color:white;-fx-padding:15;">
                        <children><Label text="Registered Users"/><Label fx:id="lblUsers" text="0"/></children>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color:white;-fx-padding:15;">
                        <children><Label text="Total Pets"/><Label fx:id="lblPets" text="0"/></children>
                    </VBox>
                </HBox>

                <Label text="Quick Actions"
                       style="-fx-font-size:22;-fx-font-weight:bold;"/>

                <FlowPane hgap="20" vgap="20">
                    <children>
                        <Button text="Approve Store" prefWidth="180" prefHeight="70" onAction="#openStores"/>
                        <Button text="Manage Pets" prefWidth="180" prefHeight="70" onAction="#openPets"/>
                        <Button text="View Reports" prefWidth="180" prefHeight="70" onAction="#openReports"/>
                        <Button text="Manage Users" prefWidth="180" prefHeight="70" onAction="#openUsers"/>
                    </children>
                </FlowPane>
            </children>
        </VBox>
    </center>
</BorderPane>
