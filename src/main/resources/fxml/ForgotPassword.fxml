<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pawpal.controller.ForgotPasswordController">

    <children>

        <HBox prefHeight="600" prefWidth="900">

            <!-- Left Panel -->

            <VBox alignment="CENTER"
                  prefWidth="450"
                  spacing="20"
                  style="-fx-background-color:#F7EAD9;">

                <children>

                    <Label text="🐾 PawPal"
                           style="-fx-font-size:34;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#355E3B;"/>

                    <Label text="Reset your password"
                           style="-fx-font-size:20;
                                  -fx-text-fill:#555555;"/>

                    <Label text="Don't worry!&#10;We'll help you recover your account."
                           style="-fx-font-size:24;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#355E3B;
                                  -fx-text-alignment:center;"/>

                </children>

            </VBox>

            <!-- Right Panel -->

            <VBox alignment="CENTER"
                  prefWidth="450"
                  spacing="15"
                  style="-fx-background-color:white;">

                <children>

                    <Label text="Forgot Password"
                           style="-fx-font-size:28;
                                  -fx-font-weight:bold;"/>

                    <TextField
                            fx:id="txtEmail"
                            promptText="Registered Email"
                            prefWidth="300"/>

                    <PasswordField
                            fx:id="txtNewPassword"
                            promptText="New Password"
                            prefWidth="300"/>

                    <PasswordField
                            fx:id="txtConfirmPassword"
                            promptText="Confirm Password"
                            prefWidth="300"/>

                    <Button
                            text="Reset Password"
                            prefWidth="300"
                            onAction="#resetPassword"
                            style="-fx-background-color:#5C7C4F;
                                   -fx-text-fill:white;
                                   -fx-font-size:15;
                                   -fx-font-weight:bold;"/>

                    <Separator prefWidth="300"/>

                    <Hyperlink
                            text="← Back To Login"
                            onAction="#backToLogin"/>

                </children>

                <padding>
                    <Insets top="20"
                            bottom="20"
                            left="20"
                            right="20"/>
                </padding>

            </VBox>

        </HBox>

    </children>

</AnchorPane>