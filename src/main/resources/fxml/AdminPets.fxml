<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700" prefWidth="1050" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pawpal.controller.AdminPetsController">
<top><HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color:#355E3B;-fx-padding:15;"><children>
<Label style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;" text="🐶 Manage Pets" />
<Pane HBox.hgrow="ALWAYS" />
<Button onAction="#loadPets" text="Refresh" />
<Button onAction="#goBack" text="Back" />
</children></HBox></top>
<center><VBox spacing="15" style="-fx-padding:20;"><children>
<TableView fx:id="tablePets" prefHeight="550">
<columns>
<TableColumn fx:id="colId" prefWidth="60" text="ID" />
<TableColumn fx:id="colName" prefWidth="160" text="Pet Name" />
<TableColumn fx:id="colType" prefWidth="100" text="Type" />
<TableColumn fx:id="colStore" prefWidth="180" text="Store" />
<TableColumn fx:id="colPrice" prefWidth="120" text="Price (BDT)" />
<TableColumn fx:id="colStatus" prefWidth="130" text="Status" />
</columns>
</TableView>
<HBox spacing="15"><children>
<Button onAction="#deletePet" style="-fx-background-color:#B33A3A;-fx-text-fill:white;" text="Delete Selected Pet" />
</children></HBox>
</children></VBox></center>
</BorderPane>
