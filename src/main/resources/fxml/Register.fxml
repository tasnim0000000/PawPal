<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0"
            prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pawpal.controller.RegisterController">

    <children>

        <HBox prefHeight="800" prefWidth="1400">

            <!-- LEFT PANEL -->

            <VBox prefWidth="400"
                  alignment="CENTER"
                  spacing="20"
                  style="-fx-background-color:#F7EAD9;">

                <children>

                    <Label text="🐾 PawPal"
                           style="-fx-font-size:36;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#355E3B;"/>

                    <Label text="Create your own pet family."
                           style="-fx-font-size:18;
                                  -fx-text-fill:#555555;"/>

                    <Label text="Every Pet Deserves&#10;A Loving Home ❤️"
                           style="-fx-font-size:28;
                                  -fx-font-weight:bold;
                                  -fx-text-alignment:center;
                                  -fx-text-fill:#355E3B;"/>

                    <Pane prefHeight="320"
                          prefWidth="320"
                          style="-fx-background-color:white;
                                 -fx-border-color:#CFCFCF;
                                 -fx-border-radius:10;
                                 -fx-background-radius:10;">

                        <children>

                            <Label layoutX="70"
                                   layoutY="145"
                                   text="Pet Illustration Here"
                                   style="-fx-font-size:18;
                                          -fx-text-fill:gray;"/>

                        </children>

                    </Pane>

                </children>

            </VBox>

            <!-- RIGHT PANEL -->

            <StackPane prefWidth="500"
                       style="-fx-background-color:white;">

                <children>

                    <VBox alignment="CENTER"
                          spacing="15"
                          maxWidth="420">

                        <children>

                            <Label text="Create Account"
                                   style="-fx-font-size:30;
                                          -fx-font-weight:bold;"/>

                            <TextField fx:id="txtName"
                                       promptText="Full Name"
                                       prefWidth="320"/>

                            <TextField fx:id="txtPhone"
                                       promptText="+8801XXXXXXXXX"
                                       prefWidth="320"/>

                            <TextField fx:id="txtEmail"
                                       promptText="Email Address"
                                       prefWidth="320"/>

                            <PasswordField fx:id="txtPassword"
                                           promptText="Password"
                                           prefWidth="320"/>

                            <PasswordField fx:id="txtConfirmPassword"
                                           promptText="Confirm Password"
                                           prefWidth="320"/>

                            <ComboBox fx:id="cmbRole"
                                      promptText="Select Role"
                                      prefWidth="320"/>

                            <Button fx:id="btnRegister"
                                    text="Create Account"
                                    prefWidth="320"
                                    onAction="#register"
                                    style="-fx-background-color:#5C7C4F;
                                           -fx-text-fill:white;
                                           -fx-font-size:15;
                                           -fx-font-weight:bold;"/>

                            <Separator prefWidth="320"/>

                            <HBox alignment="CENTER" spacing="5">

                                <children>

                                    <Label text="Already have an account?"/>

                                    <Hyperlink text="Login"
                                               onAction="#backToLogin"/>

                                </children>

                            </HBox>

                        </children>

                    </VBox>

                </children>

            </StackPane>

        </HBox>

    </children>

</AnchorPane>