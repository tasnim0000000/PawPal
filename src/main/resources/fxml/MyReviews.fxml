<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
fx:controller="com.example.pawpal.controller.MyReviewsController" prefWidth="1000" prefHeight="650">
<top><HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color:#355E3B;-fx-padding:15;"><children>
<Label text="⭐ My Reviews" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
<Pane HBox.hgrow="ALWAYS"/>
<Button text="Refresh" onAction="#loadReviews"/>
<Button text="Back" onAction="#goBack"/>
</children></HBox></top>
<center><VBox spacing="15" style="-fx-padding:20;"><children>
<TableView fx:id="tableReviews" prefHeight="520">
<columns>
<TableColumn fx:id="colPet" text="Pet" prefWidth="150"/>
<TableColumn fx:id="colStore" text="Store" prefWidth="170"/>
<TableColumn fx:id="colRating" text="Rating" prefWidth="100"/>
<TableColumn fx:id="colReview" text="Review" prefWidth="350"/>
<TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
</columns>
</TableView>
</children></VBox></center>
</BorderPane>
