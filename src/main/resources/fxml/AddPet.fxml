<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pawpal.controller.AddPetController"
            prefWidth="900"
            prefHeight="700">

    <!-- ================= TOP ================= -->

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              style="-fx-background-color:#355E3B; -fx-padding:15;">

            <children>

                <Button text="← Back"
                        onAction="#goBack"
                        style="-fx-background-color:white;
                               -fx-text-fill:#355E3B;
                               -fx-font-weight:bold;" />

                <Label text="🐾 Add New Pet"
                       style="-fx-font-size:24;
                              -fx-font-weight:bold;
                              -fx-text-fill:white;" />

            </children>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->

    <center>

        <VBox alignment="TOP_CENTER"
              spacing="12">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>

            <children>

                <TextField fx:id="txtPetName"
                           promptText="Pet Name"/>

                <ComboBox fx:id="cmbSpecies"
                          promptText="Species"/>

                <TextField fx:id="txtBreed"
                           promptText="Breed"/>

                <TextField fx:id="txtAge"
                           promptText="Age (Months)"/>

                <ComboBox fx:id="cmbGender"
                          promptText="Gender"/>

                <TextField fx:id="txtPrice"
                           promptText="Price (BDT)"/>

                <CheckBox fx:id="chkVaccinated"
                          text="Vaccinated"/>

                <TextArea fx:id="txtDescription"
                          promptText="Description"
                          prefRowCount="5"/>

                <TextField fx:id="txtImagePath"
                           promptText="Image Path (Optional)"/>

                <HBox alignment="CENTER"
                      spacing="15">

                    <children>

                        <Button text="Add Pet"
                                onAction="#addPet"/>

                        <Button text="Clear"
                                onAction="#clearForm"/>

                    </children>

                </HBox>

            </children>

        </VBox>

    </center>

</BorderPane>