<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pawpal.controller.SellerDashboardController"
            prefWidth="1200" prefHeight="750">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color:#355E3B;-fx-padding:15;">
            <children>
                <Label text="🐾 PawPal Seller"
                       style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblSeller"
                       text="Store Owner"
                       style="-fx-font-size:18;-fx-text-fill:white;"/>
                <Button text="Logout" onAction="#logout"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="220"
              style="-fx-background-color:#4F6D4A;-fx-padding:20;">
            <children>
                <Button text="🏠 Dashboard" maxWidth="Infinity" onAction="#openDashboard"/>
                <Button text="➕ Add Pet" maxWidth="Infinity" onAction="#openAddPet"/>
                <Button text="🐶 My Pets" maxWidth="Infinity" onAction="#openMyPets"/>
                <Button text="📦 Orders" maxWidth="Infinity" onAction="#openOrders"/>
                <Button text="🏪 Store Profile" maxWidth="Infinity" onAction="#openStoreProfile"/>
                <Button text="💰 Sales" maxWidth="Infinity" onAction="#openSales"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20"
              style="-fx-background-color:#F7EAD9;-fx-padding:20;">
            <children>

                <Label text="Seller Dashboard"
                       style="-fx-font-size:28;-fx-font-weight:bold;"/>

                <HBox spacing="20">

                    <VBox alignment="CENTER" prefWidth="180"
                          style="-fx-background-color:white;-fx-padding:15;">
                        <children>
                            <Label text="My Pets"/>
                            <Label fx:id="lblPets" text="0"
                                   style="-fx-font-size:26;-fx-font-weight:bold;"/>
                        </children>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="180"
                          style="-fx-background-color:white;-fx-padding:15;">
                        <children>
                            <Label text="Pending Orders"/>
                            <Label fx:id="lblPendingOrders" text="0"
                                   style="-fx-font-size:26;-fx-font-weight:bold;"/>
                        </children>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="180"
                          style="-fx-background-color:white;-fx-padding:15;">
                        <children>
                            <Label text="Completed Sales"/>
                            <Label fx:id="lblSales" text="0"
                                   style="-fx-font-size:26;-fx-font-weight:bold;"/>
                        </children>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="180"
                          style="-fx-background-color:white;-fx-padding:15;">
                        <children>
                            <Label text="Store Rating"/>
                            <Label fx:id="lblRating" text="0.0 ★"
                                   style="-fx-font-size:26;-fx-font-weight:bold;"/>
                        </children>
                    </VBox>

                </HBox>

                <Label text="Quick Actions"
                       style="-fx-font-size:22;-fx-font-weight:bold;"/>

                <FlowPane hgap="20" vgap="20">

                    <Button text="Add New Pet" prefWidth="180" prefHeight="70" onAction="#openAddPet"/>
                    <Button text="Manage Pets" prefWidth="180" prefHeight="70" onAction="#openMyPets"/>
                    <Button text="View Orders" prefWidth="180" prefHeight="70" onAction="#openOrders"/>
                    <Button text="Store Information" prefWidth="180" prefHeight="70" onAction="#openStoreProfile"/>

                </FlowPane>

                <Label text="Recent Listings"
                       style="-fx-font-size:22;-fx-font-weight:bold;"/>

                <ListView fx:id="listRecentPets" prefHeight="180"/>

            </children>
        </VBox>
    </center>

</BorderPane>
